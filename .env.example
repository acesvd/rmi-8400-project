# Claims Appeal OS - environment variables reference
# Copy to `.env` and update as needed.
# Local run scripts auto-load repo-root `.env` when present.
# For cloud deployments, set env vars in your hosting platform settings.

############################
# UI -> Backend connection #
############################

# Backend API URL used by Streamlit UI.
APPEALS_API_URL=http://localhost:8000

# HTTP timeout (seconds) for UI API calls.
APPEALS_API_TIMEOUT=120

##################
# UI demo login  #
##################

# Role-based UI credentials.
# Admin role (higher-privilege presenter account):
CLAIMRIGHT_UI_ADMIN_USERNAME=admin
CLAIMRIGHT_UI_ADMIN_PASSWORD=claimright

# Demo role (class viewers):
CLAIMRIGHT_UI_DEMO_USERNAME=demo
CLAIMRIGHT_UI_DEMO_PASSWORD=claimright-demo

# Legacy single-credential fallback (optional; used as demo credentials
# only if CLAIMRIGHT_UI_DEMO_USERNAME / CLAIMRIGHT_UI_DEMO_PASSWORD are unset).
CLAIMRIGHT_UI_USERNAME=
CLAIMRIGHT_UI_PASSWORD=

# Streamlit-side chat UI toggle (for live demos).
# true  -> chat page visible/enabled in UI
# false -> chat page hidden in nav and blocked if opened directly
CHAT_UI_ENABLED=true

############################
# Backend storage/database #
############################

# Optional override for SQLite DB location.
APPEALS_DB_PATH=storage/appeals_os.db

# Optional managed database DSN (recommended for cloud deploys).
# If set, backend uses PostgreSQL instead of local SQLite.
# Example (Cloud SQL via Unix socket on Cloud Run):
# APPEALS_DATABASE_URL=postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE
APPEALS_DATABASE_URL=

##############################
# Backend Ollama AI settings #
##############################

# Local Ollama default:
# APPEALS_OLLAMA_BASE_URL=http://localhost:11434
#
# Ollama Cloud API:
# APPEALS_OLLAMA_BASE_URL=https://ollama.com/api
#
# Accepts either host form or /api form.
APPEALS_OLLAMA_BASE_URL=http://localhost:11434

# Optional API key for hosted Ollama endpoints.
# Preferred variable:
APPEALS_OLLAMA_API_KEY=

# Backward-compatible alias (used if APPEALS_OLLAMA_API_KEY is empty).
OLLAMA_API_KEY=

# Model names:
# - local example: llama3.1
# - Ollama Cloud example: gpt-oss:20b
# If you pass a `-cloud` suffix against ollama.com, backend normalizes it.
APPEALS_OLLAMA_CHAT_MODEL=llama3.1
APPEALS_OLLAMA_EXTRACT_MODEL=llama3.1
APPEALS_OLLAMA_LETTER_MODEL=llama3.1

# Timeout (seconds) for Ollama requests from backend.
APPEALS_OLLAMA_TIMEOUT=180

###############################
# Backend chat safety controls #
###############################

# If true, chat guardrails apply to demo users (admin bypasses limits).
APPEALS_DEMO_MODE=false

# Kill switch for all chat endpoints.
APPEALS_CHAT_ENABLED=true

# Per-session cooldown (seconds) between chat messages.
APPEALS_CHAT_COOLDOWN_SECONDS=12

# Per-session maximum chat requests before blocking with HTTP 429.
APPEALS_CHAT_SESSION_MAX_REQUESTS=6

# Session usage TTL (seconds). Old session counters expire automatically.
APPEALS_CHAT_SESSION_TTL_SECONDS=21600

##################################
# Optional demo script overrides #
##################################

# Used by scripts/run_demo.sh
DEMO_API_PORT=8000
DEMO_UI_PORT=8501
DEMO_BACKEND_LOG=/tmp/appeals_backend.log
DEMO_UI_LOG=/tmp/appeals_ui.log
